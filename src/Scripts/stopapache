#!/bin/bash

# stopapache - stop the apache system service for the development environment
#
# Written by René Kreijveld - email@renekreijveld.nl
# This script is free software; you may redistribute it and/or modify it.
# This script comes without any warranty. Use it at your own risk.
#
# Version history
# 1.0 Initial version
# 1.1 Added -v verbose mode, exit codes and verification

THISVERSION=1.1

EXIT_OK=0
EXIT_BREW_MISSING=10
EXIT_STOP_FAILED=11
EXIT_VERIFY_FAILED=12

VERBOSE=0

while getopts ":v" opt; do
	case "$opt" in
	v)
		VERBOSE=1
		;;
	esac
done

log() {
	if [ "$VERBOSE" -eq 1 ]; then
		echo "$1"
	fi
}

# Stop Apache
log "Stop Apache version $THISVERSION"

if ! command -v brew >/dev/null 2>&1; then
	log "Error: Homebrew (brew) is not installed or not in PATH"
	exit $EXIT_BREW_MISSING
fi

if brew services stop httpd >/dev/null 2>&1; then
	if ps -ef | grep -E '[h]ttpd' >/dev/null 2>&1; then
		log "Error: Apache stop command returned success, but httpd is still running"
		exit $EXIT_VERIFY_FAILED
	fi

	log "Apache stopped successfully"
	exit $EXIT_OK
fi

log "Error: failed to stop Apache"
exit $EXIT_STOP_FAILED
