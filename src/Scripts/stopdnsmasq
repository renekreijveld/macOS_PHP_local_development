#!/bin/bash

# stopdnsmasq - stop the dnsmasq system service for the development environment
#
# Written by René Kreijveld - email@renekreijveld.nl
# This script is free software; you may redistribute it and/or modify it.
# This script comes without any warranty. Use it at your own risk.
#
# Version history
# 1.0 Initial version
# 1.1 Added error handling and verification, -v verbose mode and verify running process via ps output
# 1.2 Verify stop by requiring empty ps output
# 1.3 Fix false positive by checking dnsmasq daemon signature

THISVERSION=1.3

EXIT_OK=0
EXIT_BREW_MISSING=10
EXIT_STOP_FAILED=11
EXIT_VERIFY_FAILED=12

VERBOSE=0

while getopts ":v" opt; do
	case "$opt" in
	v)
		VERBOSE=1
		;;
	esac
done

log() {
	if [ "$VERBOSE" -eq 1 ]; then
		echo "$1"
	fi
}

# Stop Dnsmasq
log "Stop Dnsmasq version $THISVERSION"

if ! command -v brew >/dev/null 2>&1; then
	log "Error: Homebrew (brew) is not installed or not in PATH"
	exit $EXIT_BREW_MISSING
fi

if sudo brew services stop dnsmasq >/dev/null 2>&1; then
	if ps -ef | grep dnsmasq | grep -v grep | grep -- '--keep-in-foreground' >/dev/null 2>&1; then
		log "Error: dnsmasq stop command returned success, but dnsmasq daemon is still running"
		exit $EXIT_VERIFY_FAILED
	fi

	log "Dnsmasq stopped successfully"
	exit $EXIT_OK
fi

log "Error: failed to stop dnsmasq"
exit $EXIT_STOP_FAILED
