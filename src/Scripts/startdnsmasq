#!/bin/bash

# startdnsmasq - start dnsmasq system service for the development environment
#
# Written by René Kreijveld - email@renekreijveld.nl
# This script is free software; you may redistribute it and/or modify it.
# This script comes without any warranty. Use it at your own risk.
#
# Version history
# 1.0 Initial version
# 1.1 Added error handling and verification
# 1.2 Added -v verbose mode
# 1.3 Verify running process via ps output

THISVERSION=1.3

EXIT_OK=0
EXIT_BREW_MISSING=10
EXIT_START_FAILED=11
EXIT_VERIFY_FAILED=12

VERBOSE=0

while getopts ":v" opt; do
	case "$opt" in
	v)
		VERBOSE=1
		;;
	esac
done

log() {
	if [ "$VERBOSE" -eq 1 ]; then
		echo "$1"
	fi
}

# Start Dnsmasq
log "Start Dnsmasq version $THISVERSION"

if ! command -v brew >/dev/null 2>&1; then
	log "Error: Homebrew (brew) is not installed or not in PATH"
	exit $EXIT_BREW_MISSING
fi

if sudo brew services start dnsmasq >/dev/null 2>&1; then
	if ps -ef | grep dnsmasq | grep -v grep | grep -- '--keep-in-foreground' >/dev/null 2>&1; then
		log "Dnsmasq started successfully"
		exit $EXIT_OK
	fi

	log "Error: dnsmasq start command returned success, but no running dnsmasq process found"
	exit $EXIT_VERIFY_FAILED
fi

log "Error: failed to start dnsmasq"
exit $EXIT_START_FAILED
