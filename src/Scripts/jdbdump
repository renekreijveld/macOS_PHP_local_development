#!/bin/bash

# jdbdump -- Dump a Joomla database to SQL file.
# Supports Joomla versions 1.0 - 5.x
#
# Written by René Kreijveld - email@renekreijveld.nl
# This script is free software; you may redistribute it and/or modify it.
# This script comes without any warranty. Use it at your own risk.
#
# Version history:
# 1.6 Added use of config file
# 1.7 Added option to specify own dumpfile
# 1.8 Added -s silent option, improved password security, code cleanup

THISVERSION=1.8

MYPATH=$(cd "$(dirname "$0")"; pwd -P)
MYNAME=$(basename "$0")

# folder for phpdev configuration
CONFIG_DIR="${HOME}/.config/phpdev"
# path to the phpdev configuration file
CONFIG_FILE="${CONFIG_DIR}/config"

SILENT="no"
# Function to show messages (honoring silent mode)
showmessage() {
    if [[ "${SILENT}" == "no" ]]; then
        echo -e "$1"
    fi
}

# Display usage information
usage() {
    echo -e "${MYNAME} ${THISVERSION}, written by René Kreijveld.\n"
    echo -e "Usage: ${MYNAME} [-f dumpfile] [-n <name>] [-t] [-c] [-o] [-s] [-h]\n"
    echo "-f dumpfile, dump to specified file instead of {database}.sql (optional)."
    echo "-n the name for the website to make the database dump for."
    echo "-t Add a date-time-stamp to the database dump filename."
    echo "-c Compress the database dump with gzip."
    echo "-o Overwrite existing database dump."
    echo "-s Silent mode, no messages will be shown."
    echo -e "-h Help. Display this info.\n"
    exit 0
}

# Process the arguments
DUMPFILE=""
COMPRESS="no"
SHOWDATE="no"
OVERWRITE="no"
WEBSITE_NAME=""
while getopts "f:n:tcohs" opt; do
    case "${opt}" in
    f)
        DUMPFILE="${OPTARG}"
        ;;
    n)
        WEBSITE_NAME="${OPTARG}"
        ;;
    t)
        SHOWDATE="yes"
        ;;
    c)
        COMPRESS="yes"
        ;;
    o)
        OVERWRITE="yes"
        ;;
    s)
        SILENT="yes"
        ;;
    h)
        usage
        ;;
    \?)
        echo "Invalid option: -$OPTARG" >&2;
        exit 1
        ;;
    esac
done

showmessage "${MYNAME} ${THISVERSION}"

# Load configuration file defaults
if [[ -f "${CONFIG_FILE}" ]]; then
    source "${CONFIG_FILE}"
else
    echo "Error: configuration file ${CONFIG_FILE} not found, exiting."
    exit 1
fi   

# Check if WEBSITE_NAME is not empty
if [[ -n "${WEBSITE_NAME}" ]]; then
    WEBSITE_FOLDER="${ROOTFOLDER}/${WEBSITE_NAME}"
    if [[ ! -d "${WEBSITE_FOLDER}" ]]; then
        echo "Error: website folder ${WEBSITE_FOLDER} not found, exiting."
        exit 1
    fi
    showmessage "Going in to website folder ${WEBSITE_FOLDER}."
    cd "${WEBSITE_FOLDER}" || exit 1
fi

# Check if jfunctions script exists
if [[ ! -f "${MYPATH}/jfunctions" ]]; then
    echo "Error: Required script 'jfunctions' not found in ${MYPATH}. Exiting."
    exit 1
else
    # Gather Joomla information
    source "${MYPATH}/jfunctions"
fi

# Add a timestamp if requested
if [[ "${SHOWDATE}" == "yes" ]]; then
    NOW=$(date +".%Y%m%d-%H%M%S")
else
    NOW=""
fi

# Check for compression
if [[ "${COMPRESS}" == "yes" ]]; then
    EXTENSION=".gz"
else
    EXTENSION=""
fi

# Determine output filename
if [[ -n "${DUMPFILE}" ]]; then
    OUTFILE="${DUMPFILE}"
else
    OUTFILE="${database}${NOW}.sql"
fi

# Check if database dump exists (also check compressed version if -c is used)
if [[ -e "${OUTFILE}" ]] || { [[ "${COMPRESS}" == "yes" ]] && [[ -e "${OUTFILE}.gz" ]]; }; then
    if [[ "${OVERWRITE}" == "no" ]]; then
        read -p "Database dump ${OUTFILE}$([[ "${COMPRESS}" == "yes" ]] && echo ".gz") already exists. Press Enter to overwrite, or Ctrl-C to abort."
    else
        showmessage "Overwriting existing dump file..."
    fi
    rm -f "${OUTFILE}" "${OUTFILE}.gz" 2>/dev/null
fi

showmessage "This is a Joomla! ${jversion} site. Starting database dump."

# Create temporary credentials file for secure password handling
CREDENTIALS_FILE=$(mktemp)
chmod 600 "${CREDENTIALS_FILE}"
cat > "${CREDENTIALS_FILE}" <<EOF
[client]
user=${dbuser}
password=${password}
host=${host}
EOF

# Cleanup function to remove credentials file
cleanup() {
    rm -f "${CREDENTIALS_FILE}"
}
trap cleanup EXIT

# Create database dump using mariadb-dump with secure credentials file
if mariadb-dump --defaults-extra-file="${CREDENTIALS_FILE}" \
    --skip-opt \
    --extended-insert=FALSE \
    --add-drop-table \
    --add-locks \
    --create-options \
    --disable-keys \
    --lock-tables \
    --quick \
    --set-charset \
    "${database}" > "${OUTFILE}" 2>&1; then
    
    if [[ "${COMPRESS}" == "yes" ]]; then
        showmessage "Compressing database dump..."
        if gzip "${OUTFILE}"; then
            showmessage "Database dump is ready in ${OUTFILE}.gz."
        else
            showmessage "Error: Compression failed."
            exit 1
        fi
    else
        showmessage "Database dump is ready in ${OUTFILE}."
    fi
    exit 0
else
    showmessage "Error: Failed to create database dump."
    exit 1
fi